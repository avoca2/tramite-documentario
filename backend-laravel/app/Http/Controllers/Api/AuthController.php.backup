<?php

namespace App\Http\Controllers\Api;

use App\Http\Controllers\Controller;
use App\Models\User;
use App\Models\Estudiante;
use App\Models\VerificacionEmail;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Hash;
use Illuminate\Validation\ValidationException;
use Carbon\Carbon;

class AuthController extends Controller
{
    public function login(Request $request)
    {
        $request->validate([
            "email" => "required|email",
            "password" => "required",
        ]);

        $user = User::where("email", $request->email)->first();

        if (!$user || !Hash::check($request->password, $user->password)) {
            throw ValidationException::withMessages([
                "email" => ["Las credenciales son incorrectas."],
            ]);
        }

        $token = $user->createToken("auth_token")->plainTextToken;

        return response()->json([
            "user" => $user,
            "token" => $token
        ]);
    }

    public function register(Request $request)
    {
        // Solo validar los campos que necesitamos
        $request->validate([
            "email" => "required|string|email|max:255|unique:users",
            "dni" => "required|string|size:8",
            "codigo" => "required|string|size:6",
            "password" => "required|string|min:6|confirmed",
        ]);

        // Buscar la verificación
        $verificacion = VerificacionEmail::where("email", $request->email)
            ->where("codigo", $request->codigo)
            ->where("expira_at", ">", Carbon::now())
            ->first();

        if (!$verificacion) {
            return response()->json([
                "message" => "Código inválido o expirado. Solicita un nuevo código."
            ], 422);
        }

        // Buscar estudiante por DNI
        $estudiante = Estudiante::where("dni", $request->dni)->first();

        if (!$estudiante) {
            return response()->json([
                "message" => "No se encontró un estudiante con ese DNI."
            ], 404);
        }

        if ($estudiante->user_id) {
            return response()->json([
                "message" => "Este estudiante ya tiene un usuario registrado."
            ], 422);
        }

        // Crear usuario
        $user = User::create([
            "email" => $request->email,
            "dni" => $request->dni,
            "password" => Hash::make($request->password),
            "rol" => "estudiante",
            "activo" => true,
        ]);

        // Actualizar estudiante
        $estudiante->user_id = $user->id;
        $estudiante->email = $request->email;
        $estudiante->save();

        // Eliminar verificación
        $verificacion->delete();

        $token = $user->createToken("auth_token")->plainTextToken;

        return response()->json([
            "user" => $user,
            "estudiante" => $estudiante,
            "token" => $token,
            "message" => "¡Registro exitoso!"
        ], 201);
    }

    public function enviarCodigo(Request $request)
    {
        $request->validate([
            "email" => "required|email",
        ]);

        $codigo = str_pad(random_int(0, 999999), 6, "0", STR_PAD_LEFT);

        // Usar updateOrCreate sin campos extra
        $registro = VerificacionEmail::where("email", $request->email)->first();
        if ($registro) {
            $registro->update([
                "codigo" => $codigo,
                "expira_at" => Carbon::now()->addMinutes(10),
            ]);
        } else {
            VerificacionEmail::create([
                "email" => $request->email,
                "codigo" => $codigo,
                "expira_at" => Carbon::now()->addMinutes(10),
            ]);
        }

        return response()->json([
            "message" => "Código enviado a tu correo electrónico.",
            "codigo" => $codigo
        ], 200);
    }

    public function verificarCodigo(Request $request)
    {
        $request->validate([
            "email" => "required|email",
            "codigo" => "required|string|size:6",
        ]);

        $verificacion = VerificacionEmail::where("email", $request->email)
            ->where("codigo", $request->codigo)
            ->where("expira_at", ">", Carbon::now())
            ->first();

        if (!$verificacion) {
            return response()->json([
                "message" => "Código inválido o expirado."
            ], 422);
        }

        return response()->json([
            "message" => "Código verificado correctamente.",
            "verified" => true
        ], 200);
    }

    public function consultarDni(Request $request)
    {
        $request->validate([
            "dni" => "required|string|size:8",
        ]);

        $estudiante = Estudiante::where("dni", $request->dni)->first();

        if (!$estudiante) {
            return response()->json([
                "message" => "No se encontró un estudiante con ese DNI."
            ], 404);
        }

        return response()->json([
            "nombres" => $estudiante->nombres,
            "apellido_paterno" => $estudiante->apellido_paterno,
            "apellido_materno" => $estudiante->apellido_materno,
            "carrera_id" => $estudiante->carrera_id,
            "estudiante_id" => $estudiante->id
        ], 200);
    }

    public function logout(Request $request)
    {
        $request->user()->currentAccessToken()->delete();
        return response()->json(["message" => "Sesión cerrada correctamente"]);
    }

    public function user(Request $request)
    {
        return response()->json($request->user());
    }
}
